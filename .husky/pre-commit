#!/usr/bin/env sh
set -e

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  @stlssdev/uikit — quality-gate"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

echo ""
echo "➤ 1/4  Format …"
if pnpm exec lint-staged --config .lintstagedrc.format.json; then
  echo "  ✅ oxfmt — staged files look good"
else
  echo "  ❌ oxfmt — run \`pnpm exec oxfmt .\`, stage fixes, and try again"
  exit 1
fi

echo ""
echo "➤ 2/4  TypeScript …"
if pnpm exec tsc --noEmit; then
  echo "  ✅ tsc --noEmit passed"
else
  echo "  ❌ Typecheck failed — fix errors above"
  exit 1
fi

echo ""
echo "➤ 3/4  Lint …"
if pnpm exec lint-staged --config .lintstagedrc.lint.json; then
  echo "  ✅ oxlint — staged files look good"
else
  echo "  ❌ oxlint — run \`pnpm exec oxlint . --fix\`, review, stage, and try again"
  exit 1
fi
